{
  "name": "copilot-custom-manager",
  "displayName": "Copilot Custom Manager",
  "description": "Easily fetch and register models for GitHub Copilot Custom Endpoint providers in VS Code",
  "version": "1.1.0",
  "publisher": "jules",
  "repository": {
    "type": "git",
    "url": "https://github.com/starfall-org/copilot-custom-manager.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "icon": "icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilot-custom-manager.fetchModels",
        "title": "Copilot Custom Endpoint: Fetch and Configure Models"

      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.20.1",
    "jest": "^29.7.0",
    "sharp": "^0.35.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
